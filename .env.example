# ============================================================
# Operant - Environment Variables
# Copy this to .env.local for local dev.
# Set all of these in Vercel -> Settings -> Environment Variables.
# ============================================================

# AWS Cognito (auth only)
COGNITO_USER_POOL_ID=us-east-1_example
COGNITO_USER_POOL_CLIENT_ID=your-cognito-app-client-id
# Optional. Set only if your Cognito app client has a client secret.
# COGNITO_USER_POOL_CLIENT_SECRET=your-cognito-app-client-secret

# Used by auth redirects and checkout return URLs. Match NEXT_PUBLIC_APP_URL in production.
NEXT_PUBLIC_SITE_URL=https://operantai.xyz

# AWS Aurora PostgreSQL
# Hostname of your Aurora cluster endpoint
PGHOST=your-cluster.cluster-xxxx.us-east-1.rds.amazonaws.com
PGPORT=5432
PGDATABASE=postgres
PGUSER=postgres
PGSSLMODE=verify-full
AWS_REGION=us-east-1
# IAM role ARN that Vercel OIDC will assume to get RDS auth tokens
AWS_ROLE_ARN=arn:aws:iam::123456789012:role/your-vercel-rds-role

# AWS Secrets Manager
# JSON/text config secret used by readiness and future server-side secret hydration.
AWS_SECRETS_MANAGER_CONFIG_SECRET_ID=operant/production/app-config

# AWS S3
# Private bucket for agent files, images, and generated assets.
AGENT_ASSETS_BUCKET=operant-agent-assets

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
# Get from: Stripe Dashboard -> Webhooks -> your endpoint -> Signing secret
# Register endpoint: https://operantai.xyz/api/webhooks/stripe
# Events to subscribe: checkout.session.completed, checkout.session.async_payment_succeeded,
# checkout.session.async_payment_failed, checkout.session.expired,
# payment_intent.payment_failed, charge.refunded, charge.dispute.created
STRIPE_WEBHOOK_SECRET=whsec_...

# AI Gateway (powers all chat routes server-side)
AI_GATEWAY_API_KEY=vck_...
# On Vercel, VERCEL_OIDC_TOKEN can satisfy AI Gateway auth when enabled.

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# App
NEXT_PUBLIC_APP_URL=https://operantai.xyz
# Protects /api/readiness. Use a long random value.
READINESS_TOKEN=replace-with-a-long-random-token
# Protects /api/db-setup migration runner. Use only during setup/migrations.
SETUP_TOKEN=replace-with-a-long-random-token
